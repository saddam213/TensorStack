<CommonControls:BaseControl x:Class="TensorStack.WPF.Controls.AudioStreamElement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Behaviors="clr-namespace:TensorStack.WPF.Behaviors"
             xmlns:CommonControls="clr-namespace:TensorStack.WPF.Controls"
             xmlns:CommonConverters="clr-namespace:TensorStack.WPF.Converters" >
    <CommonControls:BaseControl.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="O" Command="{Binding LoadCommand, Mode=OneTime, RelativeSource={RelativeSource AncestorType={x:Type CommonControls:AudioStreamElement}}}" />
        <KeyBinding Modifiers="Ctrl" Key="C"  Command="{Binding CopyCommand, Mode=OneTime, RelativeSource={RelativeSource AncestorType={x:Type CommonControls:AudioStreamElement}}}" />
        <KeyBinding Modifiers="Ctrl" Key="S" Command="{Binding SaveCommand, Mode=OneTime, RelativeSource={RelativeSource AncestorType={x:Type CommonControls:AudioStreamElement}}}" />
        <KeyBinding Modifiers="Ctrl" Key="V"  Command="{Binding PasteCommand, Mode=OneTime, RelativeSource={RelativeSource AncestorType={x:Type CommonControls:AudioStreamElement}}}" />
        <KeyBinding Modifiers="Ctrl" Key="Z"  Command="{Binding ClearCommand, Mode=OneTime, RelativeSource={RelativeSource AncestorType={x:Type CommonControls:AudioStreamElement}}}" />
    </CommonControls:BaseControl.InputBindings>
    <Border DataContext="{Binding RelativeSource={RelativeSource AncestorType={x:Type CommonControls:AudioStreamElement}}, Mode=OneTime}" BorderThickness="1" BorderBrush="{StaticResource ComboBoxBorder}" Background="{StaticResource DefaultBackgroundColor}">
        <DockPanel>

            <!--Controls-->
            <DockPanel DockPanel.Dock="Bottom" Margin="-1,0,-1,-1" Height="70">

                <!--Progress-->
                <Grid DockPanel.Dock="Top">
                    <CommonControls:ProgressElement Height="6" Margin="1" Progress="{Binding Progress}" Background="Transparent"/>
                    <Slider x:Name="TrackControl"
                        Margin="1,0,1,1"
                        TickFrequency="1"
                        SmallChange="1"
                        LargeChange="1"
                        IsSnapToTickEnabled="True"
                        IsMoveToPointEnabled="True"
                        MouseLeftButtonUp="TrackControl_MouseUp"
                        Thumb.DragDelta="TrackControl_DragDelta"
                        IsEnabled="{Binding Source, Converter={StaticResource InverseNullBooleanConverter}}"/>
                </Grid>

                <!--Load/Save/View-->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button
                        ToolTip="Open Audio File" 
                        ToolTipService.Placement="Top"
                        ToolTipService.InitialShowDelay="600" 
                        Command="{Binding LoadCommand}" 
                        Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}" 
                        Visibility="{Binding IsLoadEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <CommonControls:FontAwesome Icon="f001" />
                    </Button>
                    <Button 
                        ToolTip="Save Audio File" 
                        ToolTipService.Placement="Top"
                        ToolTipService.InitialShowDelay="600" 
                        Command="{Binding SaveCommand}" 
                        Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}" 
                        Visibility="{Binding IsSaveEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <CommonControls:FontAwesome Icon="f0c7" />
                    </Button>
                    <UniformGrid Rows="1" Columns="2" Width="60" Height="26" VerticalAlignment="Center" Margin="10,0,0,0">
                        <CommonControls:ToggleButton
                            IconTrue="f04b"
                            IconFalse="f04b"
                            SizeTrue="11"
                            SizeFalse="11"
                            ColorTrue="#80FFFFFF"
                            ColorFalse="#25FFFFFF"
                            ToolTipTrue="Disable Auto-Play"
                            ToolTipFalse="Enable Auto-Play"
                            ToolTipPlacement="Top"
                            ToolTipInitialDelay="600"
                            IsChecked="{Binding IsAutoPlayEnabled, Mode=TwoWay}"/>
                        <CommonControls:ToggleButton
                            IconTrue="f363"
                            IconFalse="f363"
                            SizeTrue="11"
                            SizeFalse="11"
                            ColorTrue="#80FFFFFF"
                            ColorFalse="#25FFFFFF"
                            ToolTipTrue="Disable Auto-Replay"
                            ToolTipFalse="Enable Auto-Replay"
                            ToolTipPlacement="Top"
                            ToolTipInitialDelay="600"
                            IsChecked="{Binding IsReplayEnabled, Mode=TwoWay}"/>
                    </UniformGrid>
                </StackPanel>

                <!--Clear-->
                <Grid DockPanel.Dock="Right" Visibility="{Binding IsRemoveEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button 
                        ToolTip="Clear Audio" 
                        ToolTipService.Placement="Top"
                        ToolTipService.InitialShowDelay="600" 
                        Command="{Binding ClearCommand}" 
                        Width="{Binding ActualHeight, RelativeSource={RelativeSource Self}}"
                        Visibility="{Binding IsRemoveEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <CommonControls:FontAwesome Icon="f2ed" />
                    </Button>
                </Grid>

                <!--Audio Info-->
                <Grid>
                    <StackPanel Margin="0,0,10,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding Source.AudioCodec, Converter={StaticResource StringCaseConverter}, ConverterParameter=Upper}" Margin="10,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding ProgressPosition, FallbackValue=00:00:00, StringFormat={}mm\\:ss\\.ff}" />
                            <TextBlock Text=" / " Opacity=".7" VerticalAlignment="Center" FontStyle="Italic"/>
                            <TextBlock Text="{Binding Source.Duration, FallbackValue=00:00:00, StringFormat={}mm\\:ss\\.ff}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,-2,0,0" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding Source.SampleRate, FallbackValue=0}" />
                            <TextBlock Text=" hz  " FontSize="11" Opacity=".7" VerticalAlignment="Center" FontStyle="Italic"/>
                            <TextBlock Text="{Binding Source.Channels, FallbackValue=0}" />
                            <TextBlock Text=" channels" FontSize="11" Opacity=".7" VerticalAlignment="Center" FontStyle="Italic"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </DockPanel>

            <!--Main Content-->
            <Border x:Name="DragDropContainer">
                <Grid x:Name="MainContent" Background="Transparent" MouseLeftButtonDown="AudioControl_MouseDown">

                    <!--Audio Player-->
                    <Grid>
                        <MediaElement x:Name="AudioControl"
                            Width="0"
                            Height="0"
                            Volume="{Binding Volume}"
                            IsMuted="{Binding IsVolumeMute}"
                            LoadedBehavior="Manual" 
                            UnloadedBehavior="Close" 
                            ScrubbingEnabled="False" 
                            MediaEnded="AudioControl_MediaEnded">
                        </MediaElement>

                        <!--PlaceHolder-->
                        <Image Source="{Binding Placeholder, TargetNullValue={StaticResource PlaceholderAudio}}" Stretch="Uniform" IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Media Controls -->
                    <Popup x:Name="MediaControlsPopup"
                        StaysOpen="True"
                        Placement="Bottom"
                        VerticalOffset="-36" 
                        PopupAnimation="Fade"
                        AllowsTransparency="True"
                        Width="{Binding ActualWidth, ElementName=MainContent}" >
                        <Grid Visibility="{Binding IsMediaControlsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Height="36" 
                                Padding="10,6"
                                Margin="1,0,0,0"
                                Background="#E0232323">
                                <UniformGrid Columns="2">

                                    <!--Media Contols-->
                                    <UniformGrid Columns="4" Margin="0,0,10,0">
                                        <Button Command="{Binding PlayCommand}"  >
                                            <CommonControls:FontAwesome Icon="f04b" Size="12" />
                                        </Button>
                                        <Button Command="{Binding PauseCommand}" IsEnabled="{Binding MediaState, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Play}">
                                            <CommonControls:FontAwesome Icon="f04c" Size="12" />
                                        </Button>
                                        <Button Command="{Binding StopCommand}" >
                                            <CommonControls:FontAwesome Icon="f04d" Size="12"/>
                                        </Button>
                                        <CommonControls:ToggleButton
                                            SizeTrue="12"
                                            SizeFalse="12"
                                            IsChecked="{Binding IsVolumeMute, Mode=TwoWay}" 
                                            IconFalse="f6a9" 
                                            IconTrue="f028"
                                            ColorTrue="{StaticResource DefaultForeground}"
                                            ColorFalse="{StaticResource DefaultForeground}" >
                                        </CommonControls:ToggleButton>
                                    </UniformGrid>

                                    <!--Volume-->
                                    <Border DockPanel.Dock="Top" Padding="0,0,0,0">
                                        <DockPanel>
                                            <Grid DockPanel.Dock="Left" Width="30" >
                                                <CommonControls:FontAwesome Icon="f6a8" Size="18" Opacity=".7" Margin="0,1,0,0" Visibility="{Binding IsVolumeMute, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                                <CommonControls:FontAwesome Icon="f6a9" Size="18" Opacity=".6" Margin="2,1,0,0" Visibility="{Binding IsVolumeMute, Converter={StaticResource BooleanToVisibilityConverter}}" Color="{StaticResource WarningColour}"/>
                                            </Grid>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Volume, Converter={StaticResource DecimalToPercentConverter}, StringFormat={}{0}%}" Opacity=".7" Width="30" TextAlignment="Right" Margin="0,4,0,0"/>
                                            <Grid Margin="0,4,0,0">
                                                <Slider  Value="{Binding Volume, Mode=TwoWay}" Minimum="0" Maximum="1" TickFrequency="0.01" IsMoveToPointEnabled="True" >
                                                    <i:Interaction.Behaviors>
                                                        <Behaviors:SliderMouseWheelBehavior />
                                                    </i:Interaction.Behaviors>
                                                </Slider>
                                            </Grid>
                                        </DockPanel>
                                    </Border>

                                </UniformGrid>
                            </Border>
                        </Grid>
                        <Popup.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <BooleanAnimationUsingKeyFrames Storyboard.TargetProperty="IsOpen">
                                            <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="True"/>
                                        </BooleanAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <BooleanAnimationUsingKeyFrames Storyboard.TargetProperty="IsOpen">
                                            <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="False"/>
                                        </BooleanAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Popup.Triggers>
                    </Popup>

                    <!--DragDrop Notification-->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding AllowDrop, ElementName=DragDropContainer, Converter={StaticResource BooleanToVisibilityConverter}}" IsHitTestVisible="False">
                        <CommonControls:FontAwesome Icon="e74c" Size="30" IconStyle="SharpLight" Color="{StaticResource AccentColour2}"/>
                        <TextBlock Text="Drag &amp; Drop Audio Here" Foreground="{StaticResource AccentColour2}" FontSize="13" FontWeight="DemiBold" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!--ContextMenu-->
                    <Grid.ContextMenu>
                        <ContextMenu>
                            <!--Source-->
                            <MenuItem Header="Load" InputGestureText="Ctrl+O" Command="{Binding LoadCommand}" >
                                <MenuItem.Icon>
                                    <CommonControls:FontAwesome Icon="f07c" IconStyle="Light" Size="15" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Copy" InputGestureText="Ctrl+C" Command="{Binding CopyCommand}" >
                                <MenuItem.Icon>
                                    <CommonControls:FontAwesome Icon="f0c5" IconStyle="Light" Size="15" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Paste" InputGestureText="Ctrl+V" Command="{Binding PasteCommand}" >
                                <MenuItem.Icon>
                                    <CommonControls:FontAwesome Icon="f0ea" IconStyle="Light" Size="15"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Save" InputGestureText="Ctrl+S" Command="{Binding SaveCommand}" >
                                <MenuItem.Icon>
                                    <CommonControls:FontAwesome Icon="f0c7" IconStyle="Light" Size="15"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Clear" InputGestureText="Ctrl+Z" Command="{Binding ClearCommand}" >
                                <MenuItem.Icon>
                                    <CommonControls:FontAwesome Icon="f2ed" IconStyle="Light" Size="15"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <ContextMenu.Style>
                                <Style TargetType="{x:Type ContextMenu}" BasedOn="{StaticResource {x:Type ContextMenu}}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsInputEnabled}" Value="True"/>
                                                <Condition Binding="{Binding IsContextMenuEnabled}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <MultiDataTrigger.Setters>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger.Setters>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContextMenu.Style>
                        </ContextMenu>
                    </Grid.ContextMenu>
                </Grid>

                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="AllowDrop" Value="False"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsLoadEnabled}" Value="True" />
                                    <Condition Binding="{Binding IsInputEnabled}" Value="True" />
                                    <Condition Binding="{Binding IsDragDrop, RelativeSource={RelativeSource AncestorType=CommonControls:ViewControl}}" Value="True" />
                                    <Condition Binding="{Binding DragDropType, RelativeSource={RelativeSource AncestorType=CommonControls:ViewControl}}" Value="Audio" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="AllowDrop" Value="True"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentColour2}"/>
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsLoadEnabled}" Value="True" />
                                    <Condition Binding="{Binding IsInputEnabled}" Value="True" />
                                    <Condition Binding="{Binding IsDragDrop, RelativeSource={RelativeSource AncestorType=CommonControls:ViewControl}}" Value="True" />
                                    <Condition Binding="{Binding DragDropType, RelativeSource={RelativeSource AncestorType=CommonControls:ViewControl}}" Value="Video" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="AllowDrop" Value="True"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentColour2}"/>
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>
        </DockPanel>

        <!-- Control Triggers -->
        <Border.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <BooleanAnimationUsingKeyFrames Storyboard.TargetName="MediaControlsPopup" Storyboard.TargetProperty="IsOpen">
                            <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="True"/>
                        </BooleanAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <BooleanAnimationUsingKeyFrames Storyboard.TargetName="MediaControlsPopup" Storyboard.TargetProperty="IsOpen">
                            <DiscreteBooleanKeyFrame KeyTime="0:0:0" Value="False"/>
                        </BooleanAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
    </Border>
</CommonControls:BaseControl>
